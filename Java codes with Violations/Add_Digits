public class AddDigits {
    public int add_digits(int num) {
        while(num>=10) {
            String s = String.valueOf(num);
            int sum=0;
            for(int i=0;i<s.length();i++) {
                sum+=Character.getNumericValue(s.charAt(i));
            }
            num=sum;
        }
        return num;
    }
}
