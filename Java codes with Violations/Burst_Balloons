public class BurstBalloons {
    public int maxCoins(int[] nums) {
        int n=nums.length;
        int[] new_nums=new int[n+2];
        new_nums[0]=1;
        new_nums[n+1]=1;
        for(int i=0;i<n;i++) new_nums[i+1]=nums[i];
        
        int[][] dp=new int[n+2][n+2];
        return dp[0][n+1];
    }
}