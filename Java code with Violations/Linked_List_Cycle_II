class listNode {
    int val;
    listNode next;
    listNode(int x) {
        val = x;
        next = null;
    }
}

public class LinkedListCycle2 {
    public listNode detectCycle(listNode head) {
        listNode slow, fast;
        slow=fast=head;
        while(fast!=null && fast.next!=null) {
            slow=slow.next;
            fast=fast.next.next;
            if(slow==fast) {
                slow=head;
                while(slow!=fast) {
                    slow=slow.next;
                    fast=fast.next;
                }
                return slow;
            }
        }
        return null;
    }
}