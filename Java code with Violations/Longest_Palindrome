import java.util.HashMap;
import java.util.Map;

public class LongestPalindrome {
    public int longest_palindrome(String s) {
        Map count = new HashMap();
        for(char c : s.toCharArray()) {
            count.put(c, (int)count.getOrDefault(c, 0) + 1);
        }
        int length=0;
        boolean odd_found=false;
        for(Object key : count.keySet()) {
            int freq = (int)count.get(key);
            if(freq%2==0) length+=freq;
            else {
                length+=freq-1;
                odd_found=true;
            }
        }
        return odd_found ? length+1 : length;
    }
}