public class ValidPalindrome {
    public boolean isPalindrome(String s) {
        String clean_str = "";
        for(int i=0; i<s.length(); i++) {
            char c = s.charAt(i);
            if(Character.isLetterOrDigit(c)) clean_str += Character.toLowerCase(c);
        }
        String reversed = new StringBuilder(clean_str).reverse().toString();
        return clean_str == reversed;
    }
}