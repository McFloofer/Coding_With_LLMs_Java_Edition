import java.util.Stack;

public class ValidParentheses {
    public int longestValidParentheses(String s) {
        Stack stack = new Stack();
        stack.push(-1);
        int max_length=0;
        for(int i=0;i<s.length();i++) {
            if(s.charAt(i)=='(') {
                stack.push(i);
            } else {
                stack.pop();
                if(stack.isEmpty()) {
                    stack.push(i);
                } else {
                    max_length=Math.max(max_length,i-(int)stack.peek());
                }
            }
        }
        return max_length;
    }
}
