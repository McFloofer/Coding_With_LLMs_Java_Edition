class listNode {
    int val;
    listNode next;
    listNode(int val, listNode next) {
        this.val=val;
        this.next=next;
    }
}

public class RemoveNth {
    public listNode removeNthFromEnd(listNode head, int n) {
        listNode dummy=new listNode(0,head);
        listNode slow, fast;
        slow=fast=dummy;
        for(int i=0;i<=n;i++) fast=fast.next;
        while(fast!=null) {
            slow=slow.next;
            fast=fast.next;
        }
        slow.next=slow.next.next;
        return dummy.next;
    }
}